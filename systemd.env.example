# systemd.env — systemd-specific environment variables
# Copy to systemd.env and fill in your values.
# This file uses strict KEY=VALUE format (no spaces around =, no quotes needed).
# It is separate from .env because systemd cannot parse the python-dotenv format.

# Comma-separated wallet targets for copy-trading mode
# Format: 0xWALLET_ADDRESS:display_name
WALLETS=0xyour_wallet_address:trader_name

# Polymarket Robot — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
db_pass = your_postgres_password
# Optional overrides (defaults shown):
# DB_HOST = localhost
# DB_PORT = 5432
# DB_USER = postgres
# DB_NAME = polymarket_bot

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get your bot token from @BotFather, chat_id by running: python scripts/get_chat_id.py
telegram_bot_key = your_bot_token_from_botfather
telegram_chat_id = your_chat_id

# ── Polymarket CLOB (Copy-Trading) ───────────────────────────────────────────
# poly_private_key: EOA private key for the signer wallet (0x-prefixed, 32 bytes hex)
poly_private_key = 0xyour_private_key_here
# poly_address: The proxy wallet address that holds USDC and submits orders
poly_address = 0xyour_proxy_wallet_address

# ── Geo Validation ───────────────────────────────────────────────────────────
# Set to "True" to enforce Spain-only execution via ipinfo.io.
# Must be "True" on the production VPS (Vultr Madrid).
CHECK_GEO_IP = True

# ── Optional ──────────────────────────────────────────────────────────────────
# LOG_LEVEL = INFO

# Polymarket Robot — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# db_pass = your_postgres_password

# ── Telegram Bot (polym_check_bot) ───────────────────────────────────────────
# telegram_bot_key  = your_bot_token_from_botfather
# telegram_chat_id  = your_chat_id (run: python scripts/get_chat_id.py)

# ── Optional ──────────────────────────────────────────────────────────────────
# LOG_LEVEL = INFO
